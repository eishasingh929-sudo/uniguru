# UniGuru Backend Environment Configuration

# Server Configuration
UNIGURU_HOST=0.0.0.0
UNIGURU_PORT=8000

# Authentication
UNIGURU_API_AUTH_REQUIRED=true
UNIGURU_API_TOKEN=your-secure-token-here
UNIGURU_API_TOKENS=token1,token2,token3
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,internal-testing,uniguru-frontend

# LLM Configuration
UNIGURU_LLM_URL=http://localhost:11434/api/generate
UNIGURU_LLM_MODEL=llama2
UNIGURU_LLM_TIMEOUT_SECONDS=30

# Router Safety Controls
UNIGURU_ROUTER_QUEUE_LIMIT=100
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=5000
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=60
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true

# Feature Flags
ENABLE_BUCKET_TELEMETRY=false
ENABLE_CORE_READER=false
ENABLE_STT=true

# Knowledge Base Paths
KB_BASE_PATH=./knowledge

# Logging
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# TANTRA Ecosystem Integration (Phase 1 — Vijay SDK)
# Coordinate with Vijay Dhawan to obtain live endpoint URLs and tokens.
# ---------------------------------------------------------------

# Vijay TANTRA SDK Runtime
TANTRA_SDK_ENABLED=false
TANTRA_SDK_BASE_URL=https://<tantra-sdk-host>/api/v1
TANTRA_SDK_TOKEN=<tantra-sdk-bearer-token>
TANTRA_SDK_TIMEOUT_SECONDS=5.0

# Bucket — Live Evidence & Telemetry (Phase 2)
UNIGURU_BUCKET_TELEMETRY_ENABLED=false
UNIGURU_BUCKET_TELEMETRY_ENDPOINT=https://<bucket-host>/api/v1/events
UNIGURU_BUCKET_TELEMETRY_TOKEN=<bucket-bearer-token>
UNIGURU_BUCKET_TELEMETRY_TIMEOUT_SECONDS=2.0

# InsightFlow — Observability (Phase 3)
INSIGHTFLOW_ENABLED=false
INSIGHTFLOW_BASE_URL=https://<insightflow-host>/api/v1
INSIGHTFLOW_TOKEN=<insightflow-bearer-token>
INSIGHTFLOW_TIMEOUT_SECONDS=3.0

# GC — Governance Constitutional Validation (Phase 4)
GC_ENABLED=false
GC_BASE_URL=https://<gc-host>/api/v1
GC_TOKEN=<gc-bearer-token>
GC_TIMEOUT_SECONDS=5.0

# MDU — Schema & Provenance Validation (Phase 4)
# Live endpoint: https://bhiv-mdu-api.onrender.com
# Auth: X-API-Key header (NOT Bearer token)
# UniGuru canonical ID: BHIV-DS-UNIGURU-RUNTIME-001 (registered)
# UniGuru dataset ID:   dc02d460-8ee7-4643-88cb-8f891d991301
# UniGuru schema ID:    37c845cb-0846-4e09-93b9-62b07655ad9f
MDU_ENABLED=true
MDU_BASE_URL=https://bhiv-mdu-api.onrender.com
MDU_API_KEY=vijay_insightflow_9979621a8560aae334151df30f2d7168
MDU_TIMEOUT_SECONDS=10.0

# Core Reader (read-only reference alignment)
UNIGURU_CORE_READER_ENABLED=false
UNIGURU_CORE_BASE_URL=https://<core-host>/api/v1
UNIGURU_CORE_TOKEN=<core-bearer-token>
UNIGURU_CORE_TIMEOUT_SECONDS=2.0
