# UniGuru Backend Environment Configuration

# Server Configuration
UNIGURU_HOST=0.0.0.0
UNIGURU_PORT=8000

# Authentication
UNIGURU_API_AUTH_REQUIRED=true
UNIGURU_API_TOKEN=your-secure-token-here
UNIGURU_API_TOKENS=token1,token2,token3
UNIGURU_ALLOWED_CALLERS=bhiv-assistant,gurukul-platform,internal-testing,uniguru-frontend

# LLM Configuration
UNIGURU_LLM_URL=http://localhost:11434/api/generate
UNIGURU_LLM_MODEL=llama2
UNIGURU_LLM_TIMEOUT_SECONDS=30

# Router Safety Controls
UNIGURU_ROUTER_QUEUE_LIMIT=100
UNIGURU_ROUTER_LATENCY_THRESHOLD_MS=5000
UNIGURU_ROUTER_CIRCUIT_OPEN_SECONDS=60
UNIGURU_ROUTER_UNVERIFIED_FALLBACK=true

# Feature Flags
ENABLE_BUCKET_TELEMETRY=false
ENABLE_CORE_READER=false
ENABLE_STT=true

# Knowledge Base Paths
KB_BASE_PATH=./knowledge

# Logging
LOG_LEVEL=INFO
